<?xml version="1.0" encoding="utf-8"?>
<resources>

  <string name="appName">ManosYA</string>
  <string name="launcherName">ManosYA</string>

  <!-- HOST del dominio principal (importante que coincida con tu TWA) -->
  <string name="hostName">www.manosya.app</string>

  <!-- URL de arranque de la app TWA -->
  <string name="launchUrl">https://www.manosya.app/?source=twa</string>

  <!-- URL de tu manifest web (Next/PWA) -->
  <string name="webManifestUrl">https://www.manosya.app/manifest.json</string>

  <!-- Autoridad del FileProvider (dejalo así si no estás seguro) -->
  <string name="providerAuthority">app.manosya.client.fileprovider</string>

  <!-- Fallback -->
  <string name="fallbackType">customtabs</string>

  <!-- Orientación -->
  <string name="orientation">portrait</string>

  <!-- Generator (texto libre) -->
  <string name="generatorApp">bubblewrap</string>

  <!-- Digital Asset Links statement (relación app <-> sitio) -->
  <string name="assetStatements">
    [{
      \"relation\": [\"delegate_permission/common.handle_all_urls\"],
      \"target\": {
        \"namespace\": \"web\",
        \"site\": \"https://www.manosya.app\"
      }
    }]
  </string>

</resources>